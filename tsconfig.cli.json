{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist-cli",
    "rootDir": ".",
    "types": ["node"],
    "lib": ["ES2023"]
  },
  "include": ["cli/**/*.ts", "shared/**/*.ts"]
}
